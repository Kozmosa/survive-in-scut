{
  "name": "survive-in-scut",
  "version": "0.1.0",
  "description": "A survive manual for freshman to South China University of Technology",
  "license": "CC",
  "packageManager": "npm@11.18.0",
  "type": "module",
  "scripts": {
    "docs:build": "vuepress build docs",
    "docs:sync:vitepress-public": "node scripts/sync-vitepress-public.js",
    "docs:build:vitepress": "npm run docs:sync:vitepress-public && vitepress build docs",
    "docs:build:platform": "node scripts/docs-build-platform.js",
    "docs:clean-dev": "vuepress dev docs --clean-cache",
    "docs:dev": "vuepress dev docs",
    "docs:dev:vitepress": "npm run docs:sync:vitepress-public && vitepress dev docs",
    "docs:preview:vitepress": "npm run docs:sync:vitepress-public && vitepress preview docs",
    "docs:update-package": "npx vp-update",
    "docs:fmt": "prettier --write --check \"**/*.{js,json,md}\""
  },
  "devDependencies": {
    "@vuepress/bundler-vite": "^2.0.0-rc.30",
    "@vuepress/plugin-back-to-top": "^2.0.0-rc.131",
    "@vuepress/plugin-comment": "^2.0.0-rc.131",
    "@vuepress/plugin-copy-code": "^2.0.0-rc.131",
    "@vuepress/plugin-prismjs": "^2.0.0-rc.131",
    "@vuepress/plugin-reading-time": "^2.0.0-rc.131",
    "@vuepress/plugin-search": "^2.0.0-rc.131",
    "@vuepress/theme-default": "^2.0.0-rc.131",
    "@waline/client": "^3.15.2",
    "sass": "^1.101.0",
    "sass-embedded": "^1.100.0",
    "vitepress": "^2.0.0-alpha.17",
    "vue": "^3.5.39",
    "vuepress": "^2.0.0-rc.30"
  },
  "dependencies": {
    "dompurify": "^3.4.11",
    "highlight.js": "^11.11.1",
    "marked": "^15.0.12",
    "pdfjs-dist": "^6.1.200",
    "prettier": "^3.9.4",
    "vuepress-plugin-todo-collector": "file:packages/vuepress-plugin-todo"
  },
  "allowScripts": {
    "@parcel/watcher@2.5.6": true,
    "esbuild@0.28.1": true
  },
  "overrides": {
    "encoding-sniffer": "^1.0.2"
  }
}
