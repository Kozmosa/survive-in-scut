{
  "name": "survive-in-scut",
  "version": "0.1.0",
  "description": "A survive manual for freshman to South China University of Technology",
  "license": "CC",
  "type": "module",
  "scripts": {
    "docs:sync:vitepress-public": "node scripts/sync-vitepress-public.js",
    "docs:build": "npm run docs:sync:vitepress-public && vitepress build docs",
    "docs:dev": "npm run docs:sync:vitepress-public && vitepress dev docs",
    "docs:preview": "vitepress preview docs",
    "docs:build:platform": "node scripts/docs-build-platform.js",
    "docs:fmt": "prettier --check '**/*.{js,ts,json,md,vue,html,yml}'",
    "docs:fmt:fix": "prettier --write '**/*.{js,ts,json,md,vue,html,yml}'",
    "prepare": "simple-git-hooks"
  },
  "lint-staged": {
    "*.{js,ts,json,md,vue,html,yml}": "prettier --write"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged",
    "pre-push": "if test -f scripts/pre-push-check.sh; then bash scripts/pre-push-check.sh; fi"
  },
  "devDependencies": {
    "lint-staged": "^17.0.8",
    "markdown-it-mathjax3": "^4.3.2",
    "prettier": "^3.9.5",
    "simple-git-hooks": "^2.13.1",
    "vitepress": "^2.0.0-alpha.17",
    "vitepress-plugin-llms": "^1.13.3",
    "vue": "^3.5.16"
  },
  "dependencies": {
    "@waline/client": "^3.5.7",
    "dompurify": "^3.2.6",
    "highlight.js": "^11.11.1",
    "marked": "^15.0.12",
    "pdfjs-dist": "^6.1.200"
  },
  "allowScripts": {
    "simple-git-hooks@2.13.1": true
  }
}
